    self.logger.info(f"HIST4H: {hist4:.2f} (DIF4H: {dif4:.2f}, DEA4H: {dea4:.2f})")
    self.logger.info(f"J_4H: {j_4h:.2f}")
    self.logger.info(f"--- 1天指标 ---")
    self.logger.info(f"HIST1D: {hist1d:.2f} (DIF1D: {dif1d:.2f}, DEA1D: {dea1d:.2f})")
    self.logger.info(f"--- 信号原因 ---")
    self.logger.info(f"通过检查: {long_reason}")
    self.logger.info("=" * 80)

    return Signal(
        action='open',
        side='long',
        reason='V5多头信号',
        confidence=0.8,
