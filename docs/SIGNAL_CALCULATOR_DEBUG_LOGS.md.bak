    self.logger.info(f"HIST15均值2: {row.get('hist15_mean_2', 0):.2f}")
    self.logger.info(f"--- 1小时指标 ---")
    self.logger.info(f"HIST1H: {hist1h:.2f} (DIF1H: {dif1h:.2f}, DEA1H: {dea1h:.2f})")
    self.logger.info(f"J_1H: {j_1h:.2f}")
